FROM node:24

ARG CLAUDE_CODE_VERSION=latest
ARG TZ=UTC

# Set timezone before package install so tzdata uses it non-interactively
ENV TZ=${TZ}

# Switch to HTTPS for apt sources (HTTP downloads large packages unreliably in some network environments)
# ca-certificates is pre-installed in node:24, so HTTPS works immediately
RUN find /etc/apt -name '*.list' -o -name '*.sources' | \
    xargs sed -i 's|http://deb\.debian\.org|https://deb.debian.org|g'

# Install Claude Code dependencies (required for all projects)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      git gh jq fzf unzip procps tzdata && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install project-specific packages listed in packages.txt
COPY packages.txt /tmp/packages.txt
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      $(grep -v '^\s*#\|^\s*$' /tmp/packages.txt | tr '\n' ' ') && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Python packages listed in requirements.txt
COPY requirements.txt /tmp/requirements.txt
RUN pip3 install -r /tmp/requirements.txt --break-system-packages

# Ensure default node user has access to /usr/local/share
RUN mkdir -p /usr/local/share/npm-global && \
  chown -R node:node /usr/local/share

# Set DEVCONTAINER environment variable to help with orientation
ENV DEVCONTAINER=true

# Create workspace and config directories and set permissions
RUN mkdir -p /workspace /home/node/.claude && \
  chown -R node:node /workspace /home/node/.claude

WORKDIR /workspace

# Set up non-root user
USER node

# Persist bash history to /workspace/.claude/bash_history
RUN echo "export PROMPT_COMMAND='mkdir -p /workspace/.claude && history -a'" >> /home/node/.bashrc \
  && echo "export HISTFILE=/workspace/.claude/bash_history" >> /home/node/.bashrc

# Install global npm packages
ENV NPM_CONFIG_PREFIX=/usr/local/share/npm-global
ENV PATH=$PATH:/usr/local/share/npm-global/bin

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}

CMD ["claude", "--dangerously-skip-permissions"]
